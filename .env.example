# PostgreSQL
POSTGRES_DB=ink
POSTGRES_USER=ink_user
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5433

# Spring Boot datasource when backend runs locally on your machine
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/ink
SPRING_DATASOURCE_USERNAME=ink_user
SPRING_DATASOURCE_PASSWORD=change_me

# Spring profile
SPRING_PROFILES_ACTIVE=dev

# Backend
BACKEND_PORT=8080

# Frontend
FRONTEND_PORT=4200

# JWT
JWT_SECRET=replace_with_at_least_256_bit_secret
JWT_ACCESS_TOKEN_TTL_MINUTES=60
JWT_REFRESH_TOKEN_TTL_DAYS=30

# RATE LIMIT
RATE_LIMIT_AUTH_CAPACITY=5
RATE_LIMIT_AUTH_REFILL_MINUTES=1
RATE_LIMIT_AUTH_GLOBAL_CAPACITY=120
RATE_LIMIT_AUTH_GLOBAL_REFILL_MINUTES=1
RATE_LIMIT_BUCKET_EXPIRY_MINUTES=15
RATE_LIMIT_MAX_BUCKETS=10000
# Keep true only behind a proxy that overwrites client-supplied X-Forwarded-For.
RATE_LIMIT_TRUST_FORWARDED_FOR=true
